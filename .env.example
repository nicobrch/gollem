GATEWAY_ADMIN_API_KEY=gw-admin-dev-key
GATEWAY_KEYS_BACKEND=file
GATEWAY_KEYS_FILE=./data/gateway_keys.json
# GATEWAY_KEYS_POSTGRES_DSN=postgres://gollem:gollem@localhost:5432/gollem?sslmode=disable
AZURE_OPENAI_API_KEY=your-azure-openai-key
PORT=8000
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt4o
AZURE_OPENAI_API_VERSION=2024-10-21
DEFAULT_MODEL=gpt4o
REQUEST_TIMEOUT_SECONDS=60
MAX_BODY_BYTES=1048576
MAX_INFLIGHT_REQUESTS=0
LOG_PROMPT_SUMMARIES=false
LOG_RESPONSE_SUMMARIES=false

SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_REDIS_ADDR=localhost:6379
# SEMANTIC_CACHE_REDIS_PASSWORD=
SEMANTIC_CACHE_REDIS_DB=0
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_CANDIDATES=50
SEMANTIC_CACHE_MAX_ENTRIES_PER_SCOPE=200
SEMANTIC_CACHE_MAX_RESPONSE_BYTES=1048576
# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small
