GATEWAY_API_KEY=gw-legacy-dev-key
GATEWAY_ADMIN_API_KEY=gw-admin-dev-key
ALLOW_LEGACY_ADMIN_KEY_FALLBACK=false
GATEWAY_KEYS_FILE=./data/gateway_keys.json
AZURE_OPENAI_API_KEY=your-azure-openai-key
PORT=8000
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt4o
AZURE_OPENAI_API_VERSION=2024-10-21
DEFAULT_MODEL=gpt4o
REQUEST_TIMEOUT_SECONDS=60
MAX_BODY_BYTES=1048576
MAX_INFLIGHT_REQUESTS=0
LOG_PROMPT_SUMMARIES=false
LOG_RESPONSE_SUMMARIES=false
