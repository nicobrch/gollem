PORT=8000
LISTEN_ADDR=:8000

GATEWAY_ADMIN_API_KEY=gw-admin-dev-key
GATEWAY_KEYS_BACKEND=postgres
GATEWAY_KEYS_POSTGRES_DSN=postgres://gollem:gollem@postgres:5432/gollem?sslmode=disable

AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt4o
AZURE_OPENAI_API_VERSION=2024-10-21

REQUEST_TIMEOUT_SECONDS=60
MAX_BODY_BYTES=1048576
MAX_INFLIGHT_REQUESTS=0
LOG_PROMPT_SUMMARIES=false
LOG_RESPONSE_SUMMARIES=false

POSTGRES_DB=gollem
POSTGRES_USER=gollem
POSTGRES_PASSWORD=gollem
